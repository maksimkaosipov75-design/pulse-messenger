{
  "productName": "ember",
  "version": "1.0.0",
  "identifier": "com.pulse.messenger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ember",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: asset: http://asset.localhost https:; media-src 'self' blob: asset: http://asset.localhost; connect-src 'self' ipc: tauri: asset:; font-src 'self' data: asset:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$TEMP/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/maksimkaosipov75-design/pulse-messenger/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBREJFNjJENkVCODBEQTMKUldTakRiaHVMZWJiK2pjTDJ4dDFMYldTVlBnVzRtZXFzQzBJZnpXTnV0WGp6ejh3YkNWN2JGbGkK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "android": {
      "minSdkVersion": 26
    }
  }
}
